# ============================================================
# InfectionIQ Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# --- Application ---
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # false in production
LOG_LEVEL=INFO

# --- Database ---
# Development (SQLite):
DATABASE_URL=sqlite:///./infectioniq.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql://user:password@localhost:5432/infectioniq
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis ---
# Leave empty for fakeredis in development
REDIS_URL=
USE_FAKEREDIS=true
# Production:
# REDIS_URL=redis://localhost:6379/0
# USE_FAKEREDIS=false

# --- Supabase (primary auth) ---
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# --- Security (REQUIRED in production) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Password Policy ---
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
# Production:
# CORS_ORIGINS=["https://your-domain.com"]

# --- HIPAA / PHI Encryption ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PHI_ENCRYPTION_KEY=

# --- SSO / SAML (optional) ---
SSO_ENABLED=false
SSO_ENTITY_ID=
SSO_SSO_URL=
SSO_SLO_URL=
SSO_X509_CERT=
SSO_SP_ENTITY_ID=infectioniq-sp
SSO_ACS_URL=

# --- FHIR / EMR ---
FHIR_ENABLED=true
FHIR_SERVER_URL=

# --- Consent ---
CONSENT_REQUIRED_TYPES=["DATA_COLLECTION","AI_MONITORING"]

# --- Frontend (Vite) ---
VITE_API_URL=
VITE_WS_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Alert Channels ---
# SMTP Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=alerts@infectioniq.local
ALERT_EMAIL_RECIPIENTS=[]

# PagerDuty
PAGERDUTY_ROUTING_KEY=

# SMS (webhook-based)
SMS_WEBHOOK_URL=
SMS_WEBHOOK_AUTH_TOKEN=

# Generic Webhook
WEBHOOK_ALERT_URL=
WEBHOOK_ALERT_SECRET=

# --- Audit ---
AUDIT_RETENTION_DAYS=90

# --- PostgreSQL (Docker) ---
POSTGRES_DB=infectioniq
POSTGRES_USER=infectioniq
POSTGRES_PASSWORD=changeme_in_production
REDIS_PASSWORD=
