{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(infectioniq_http_requests_total[1m]))",
          "legendFormat": "Total RPS",
          "refId": "A"
        },
        {
          "expr": "sum(rate(infectioniq_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx Errors",
          "refId": "B"
        },
        {
          "expr": "sum(rate(infectioniq_http_requests_total{status=\"429\"}[1m]))",
          "legendFormat": "429 Rate Limited",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "5xx Errors" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "429 Rate Limited" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 2,
      "title": "Response Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(infectioniq_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(infectioniq_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(infectioniq_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 0.5, "color": "yellow" }, { "value": 2.0, "color": "red" }] }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Requests by Endpoint (Top 10)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(infectioniq_http_requests_total[5m])) by (endpoint))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" } },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Error Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(5, sum(rate(infectioniq_http_requests_total{status=~\"[45]..\"}[5m])) by (endpoint))",
          "legendFormat": "{{ endpoint }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Camera Fleet",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "title": "Cameras Online",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "infectioniq_cameras_online", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "value", "textMode": "value" }
    },
    {
      "id": 12,
      "title": "Cameras Offline",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "infectioniq_cameras_offline", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "value", "textMode": "value" }
    },
    {
      "id": 13,
      "title": "Total Cameras",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "infectioniq_cameras_registered_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] }, "mappings": [] },
        "overrides": []
      },
      "options": { "graphMode": "none", "colorMode": "value", "textMode": "value" }
    },
    {
      "id": 14,
      "title": "Camera Heartbeat Age (seconds)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "infectioniq_camera_heartbeat_age_seconds",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true }, "renameByName": { "camera_id": "Camera", "or_number": "OR", "Value": "Age (s)" } } }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Age (s)" }, "properties": [{ "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 30, "color": "yellow" }, { "value": 60, "color": "red" }] } }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      }
    },
    {
      "id": 20,
      "title": "Alerts & Operations",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "title": "Alerts Sent (by type)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(infectioniq_alerts_sent_total[5m])) by (alert_type)",
          "legendFormat": "{{ alert_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never", "stacking": { "mode": "normal" } } },
        "overrides": []
      }
    },
    {
      "id": 22,
      "title": "Alert Failures (by channel)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(infectioniq_alerts_failed_total[5m])) by (channel)",
          "legendFormat": "{{ channel }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 15, "showPoints": "never" }, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 23,
      "title": "Alerts by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(infectioniq_alerts_sent_total) by (severity)",
          "legendFormat": "{{ severity }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HIGH" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "MEDIUM" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "LOW" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 24,
      "title": "Alerts by Channel",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(infectioniq_alerts_sent_total) by (channel)",
          "legendFormat": "{{ channel }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 25,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "infectioniq_websocket_connections_active", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "value" }
    },
    {
      "id": 26,
      "title": "Active Surgical Cases",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [{ "expr": "infectioniq_cases_active", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 10, "color": "yellow" }, { "value": 20, "color": "red" }] } },
        "overrides": []
      },
      "options": { "graphMode": "area", "colorMode": "value", "textMode": "value" }
    },
    {
      "id": 30,
      "title": "Background Scheduler",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "title": "Scheduled Task Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(infectioniq_scheduled_task_duration_seconds_bucket[15m])) by (le, task_name))",
          "legendFormat": "{{ task_name }} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      }
    },
    {
      "id": 32,
      "title": "Scheduled Task Failures",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(infectioniq_scheduled_task_failures_total[5m])) by (task_name)",
          "legendFormat": "{{ task_name }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "never" }, "color": { "mode": "palette-classic" } },
        "overrides": []
      }
    },
    {
      "id": 40,
      "title": "Endpoint Latency Heatmap",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "title": "Response Time by Endpoint (p95)",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "topk(15, histogram_quantile(0.95, sum(rate(infectioniq_http_request_duration_seconds_bucket[5m])) by (le, endpoint)))",
          "legendFormat": "{{ endpoint }}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 0.25, "color": "yellow" }, { "value": 1.0, "color": "red" }] }
        },
        "overrides": []
      },
      "options": { "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true, "minVizWidth": 0, "minVizHeight": 10 }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["infectioniq", "backend", "monitoring"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "InfectionIQ Overview",
  "uid": "infectioniq-overview",
  "version": 1
}
